<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="MailApp">
  <Id>eef5c758-5e9f-489c-8351-e49c506e437e</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>AAE</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="MailLighter">
    <Override Locale="fr-fr" Value="MailLighter"/>
  </DisplayName>
  <Description DefaultValue="The best way to clean your emails.">
    <Override Locale="fr-fr" Value="La meilleure façon de nettoyer vos emails."/>
  </Description>
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://www.maillighter.com/help"/>
  <AppDomains>
    <AppDomain>https://www.maillighter.com</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3000/commands.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3000/commands.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Menu" id="msgReadMenuButton">
                  <Label resid="MenuButton.Label"/>
                  <Supertip>
                    <Title resid="MenuButton.Label"/>
                    <Description resid="MenuButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Items>
                    <Item id="msgReadRemoveImagesItem">
                      <Label resid="RemoveImages.Label"/>
                      <Supertip>
                        <Title resid="RemoveImages.Label"/>
                        <Description resid="RemoveImages.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16"/>
                        <bt:Image size="32" resid="Icon.32x32"/>
                        <bt:Image size="80" resid="Icon.80x80"/>
                      </Icon>
                      <Action xsi:type="ExecuteFunction">
                        <FunctionName>removeImagesCommand</FunctionName>
                      </Action>
                    </Item>
                    <Item id="msgReadRemoveAttachmentsItem">
                      <Label resid="RemoveAttachments.Label"/>
                      <Supertip>
                        <Title resid="RemoveAttachments.Label"/>
                        <Description resid="RemoveAttachments.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16"/>
                        <bt:Image size="32" resid="Icon.32x32"/>
                        <bt:Image size="80" resid="Icon.80x80"/>
                      </Icon>
                      <Action xsi:type="ExecuteFunction">
                        <FunctionName>removeAttachmentsCommand</FunctionName>
                      </Action>
                    </Item>
                    <Item id="msgReadKeepTwoRepliesItem">
                      <Label resid="KeepTwoReplies.Label"/>
                      <Supertip>
                        <Title resid="KeepTwoReplies.Label"/>
                        <Description resid="KeepTwoReplies.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16"/>
                        <bt:Image size="32" resid="Icon.32x32"/>
                        <bt:Image size="80" resid="Icon.80x80"/>
                      </Icon>
                      <Action xsi:type="ExecuteFunction">
                        <FunctionName>keepTwoRepliesCommand</FunctionName>
                      </Action>
                    </Item>
                    <Item id="msgReadCleanAllItem">
                      <Label resid="CleanAll.Label"/>
                      <Supertip>
                        <Title resid="CleanAll.Label"/>
                        <Description resid="CleanAll.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16"/>
                        <bt:Image size="32" resid="Icon.32x32"/>
                        <bt:Image size="80" resid="Icon.80x80"/>
                      </Icon>
                      <Action xsi:type="ExecuteFunction">
                        <FunctionName>cleanAllCommand</FunctionName>
                      </Action>
                    </Item>
                  </Items>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Menu" id="msgComposeMenuButton">
                  <Label resid="MenuButton.Label"/>
                  <Supertip>
                    <Title resid="MenuButton.Label"/>
                    <Description resid="MenuButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Items>
                    <Item id="msgComposeRemoveImagesItem">
                      <Label resid="RemoveImages.Label"/>
                      <Supertip>
                        <Title resid="RemoveImages.Label"/>
                        <Description resid="RemoveImages.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16"/>
                        <bt:Image size="32" resid="Icon.32x32"/>
                        <bt:Image size="80" resid="Icon.80x80"/>
                      </Icon>
                      <Action xsi:type="ExecuteFunction">
                        <FunctionName>removeImagesCommand</FunctionName>
                      </Action>
                    </Item>
                    <Item id="msgComposeRemoveAttachmentsItem">
                      <Label resid="RemoveAttachments.Label"/>
                      <Supertip>
                        <Title resid="RemoveAttachments.Label"/>
                        <Description resid="RemoveAttachments.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16"/>
                        <bt:Image size="32" resid="Icon.32x32"/>
                        <bt:Image size="80" resid="Icon.80x80"/>
                      </Icon>
                      <Action xsi:type="ExecuteFunction">
                        <FunctionName>removeAttachmentsCommand</FunctionName>
                      </Action>
                    </Item>
                    <Item id="msgComposeKeepTwoRepliesItem">
                      <Label resid="KeepTwoReplies.Label"/>
                      <Supertip>
                        <Title resid="KeepTwoReplies.Label"/>
                        <Description resid="KeepTwoReplies.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16"/>
                        <bt:Image size="32" resid="Icon.32x32"/>
                        <bt:Image size="80" resid="Icon.80x80"/>
                      </Icon>
                      <Action xsi:type="ExecuteFunction">
                        <FunctionName>keepTwoRepliesCommand</FunctionName>
                      </Action>
                    </Item>
                    <Item id="msgComposeCleanAllItem">
                      <Label resid="CleanAll.Label"/>
                      <Supertip>
                        <Title resid="CleanAll.Label"/>
                        <Description resid="CleanAll.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16"/>
                        <bt:Image size="32" resid="Icon.32x32"/>
                        <bt:Image size="80" resid="Icon.80x80"/>
                      </Icon>
                      <Action xsi:type="ExecuteFunction">
                        <FunctionName>cleanAllCommand</FunctionName>
                      </Action>
                    </Item>
                  </Items>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://localhost:3000/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://localhost:3000/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://localhost:3000/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://localhost:3000/commands.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="MailLighter Add-in">
          <bt:Override Locale="fr-fr" Value="MailLighter Add-in"/>
        </bt:String>
        <bt:String id="MenuButton.Label" DefaultValue="MailLighter">
          <bt:Override Locale="fr-fr" Value="MailLighter"/>
        </bt:String>
        <bt:String id="RemoveImages.Label" DefaultValue="Remove images">
          <bt:Override Locale="fr-fr" Value="Supprimer les images"/>
        </bt:String>
        <bt:String id="RemoveAttachments.Label" DefaultValue="Remove attachments">
          <bt:Override Locale="fr-fr" Value="Supprimer les pièces jointes"/>
        </bt:String>
        <bt:String id="KeepTwoReplies.Label" DefaultValue="Keep latest 2 replies">
          <bt:Override Locale="fr-fr" Value="Conserver 2 réponses"/>
        </bt:String>
        <bt:String id="CleanAll.Label" DefaultValue="Full cleanup">
          <bt:Override Locale="fr-fr" Value="Nettoyage complet"/>
        </bt:String>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="MenuButton.Tooltip" DefaultValue="Open MailLighter actions menu.">
          <bt:Override Locale="fr-fr" Value="Ouvre le menu d’actions MailLighter."/>
        </bt:String>
        <bt:String id="RemoveImages.Tooltip" DefaultValue="Remove images from the current email.">
          <bt:Override Locale="fr-fr" Value="Supprime les images du mail courant."/>
        </bt:String>
        <bt:String id="RemoveAttachments.Tooltip" DefaultValue="Remove attachments from the current draft.">
          <bt:Override Locale="fr-fr" Value="Supprime les pièces jointes du brouillon courant."/>
        </bt:String>
        <bt:String id="KeepTwoReplies.Tooltip" DefaultValue="Keep only the latest 2 replies.">
          <bt:Override Locale="fr-fr" Value="Conserve uniquement les deux derniers replies."/>
        </bt:String>
        <bt:String id="CleanAll.Tooltip" DefaultValue="Run all cleanup actions.">
          <bt:Override Locale="fr-fr" Value="Applique toutes les actions de nettoyage."/>
        </bt:String>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>